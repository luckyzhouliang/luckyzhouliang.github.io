    <title>python笔记</title>
    <link href="https://luckyzhouliang.github.io/2021/10/06/python%E7%AC%94%E8%AE%B0/"/>
    <id>https://luckyzhouliang.github.io/2021/10/06/python%E7%AC%94%E8%AE%B0/</id>
